# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/interview-simulator?retryWrites=true&w=majority

# AI Provider — use one of these:
# Option 1: OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# Option 2: Gemini (Google)
GEMINI_API_KEY=your-gemini-key-here

# AI Provider flag: "openai" or "gemini"
AI_PROVIDER=openai
